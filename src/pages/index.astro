---
import Layout from '../layouts/Layout.astro';

// Content Matrix
const focusBadges = ["Data Science", "Experimentation", "Analytics Engineering", "Predictive Modeling", "Applied AI"];

const specializations = [
  {
    title: "Data Science & Modeling",
    description: "Predictive modeling, forecasting, segmentation, valuation, experimentation, and statistical analysis grounded in real operational and commercial use cases."
  },
  {
    title: "Analytics Engineering",
    description: "Python, SQL, dashboards, KPI systems, ETL workflows, and reliable data foundations for decision-making across product, sales, and operations."
  },
  {
    title: "Industry Experience",
    description: "Experience across AdTech, consulting, and automobile insurance claims management, with strong exposure to performance analytics, process automation, and business-facing problem solving."
  },
  {
    title: "Responsible Applied AI",
    description: "Interested in AI systems that are practical, private, and useful—from production ML pipelines to local-first assistants and workflows designed with GDPR, efficiency, and real user value in mind."
  }
];

const philosophy = [
  {
    key: "Calculation first",
    val: "Breaking messy real-world problems into measurable systems."
  },
  {
    key: "Data for good",
    val: "Focus on fairness, efficiency, sustainability, and socially useful outcomes."
  },
  {
    key: "Environmental analytics",
    val: "Tracking CO2 emissions, climate/economic datasets, and analytical approaches that improve systemic understanding."
  },
  {
    key: "Human side",
    val: "Coffee, latte art, and badminton bring energy, patience, rhythm, and precision to the workflow."
  }
];

const currentFocus = {
  copy: "Right now I am learning and building end-to-end AI chatbots and workflow systems using local and private infrastructure.",
  bullets: [
    "Local AI models and agent workflows (Qwen, Hermes, OpenWebUI, LiteLLM, MCP)",
    "Private, GDPR-conscious AI infrastructure",
    "Internal assistants for support, knowledge work, and operational workflows"
  ]
};

const techStack = [
  { category: "Languages", items: ["Python", "SQL", "R"] },
  { category: "Data Science", items: ["Scikit-learn", "Pandas", "NumPy", "PySpark", "MLflow"] },
  { category: "Analytics & BI", items: ["Tableau", "Power BI", "Looker", "A/B Testing", "Causal Inference"] },
  { category: "Cloud & Data", items: ["AWS", "GCP", "BigQuery", "Redshift", "Athena", "Airflow"] },
  { category: "Current AI Stack", items: ["Qwen", "Hermes", "LiteLLM", "OpenWebUI", "MCP", "local LLM workflows"] }
];

const timeline = [
  {
    time: "Present",
    company: "WinValue (Germany)",
    description: "Building analytical products and data systems in automobile insurance claims and valuation, including OCR pipelines, predictive models, reporting systems, and automation workflows."
  },
  {
    time: "Past",
    company: "Criteo",
    description: "Worked on large-scale AdTech analytics, experimentation, campaign performance measurement, LTV modeling, bidding optimization, and data pipelines processing terabytes of event data."
  },
  {
    time: "Past",
    company: "KPMG",
    description: "Delivered Python- and SQL-based analytics work for enterprise clients, identifying control gaps, anomalies, and opportunities for better decisions."
  },
  {
    time: "Past",
    company: "Accenture",
    description: "Early foundation in software engineering, application development, and working in production-focused delivery environments."
  },
  {
    time: "Research",
    company: "TU Braunschweig",
    description: "Worked on causal inference, econometric modeling, climate/economic datasets, and AI-driven research with a strong methodological basis."
  }
];

const projects = [
  {
    title: "Claims & Valuation Intelligence",
    tag: "Insurance / Predictive Modeling",
    description: "Applied machine learning and analytics engineering to automobile insurance claims, valuation workflows, OCR extraction, and structured decision support."
  },
  {
    title: "Experimentation at Scale",
    tag: "AdTech / Data Science",
    description: "Designed and analyzed hundreds of A/B tests on pricing, bidding, and product changes, translating experimental results into commercial action."
  },
  {
    title: "High-Volume Data Systems",
    tag: "Analytics Engineering / Scale",
    description: "Built Python, SQL, and PySpark workflows for large-scale reporting, modeling, and trustworthy data quality across operational systems."
  },
  {
    title: "Local & Private AI Workflows",
    tag: "Current Focus / Applied AI",
    description: "Building local-first and privacy-conscious AI assistants and chatbot workflows using modern open model stacks and orchestration tooling."
  }
];
---

<Layout>
  <!-- Main Grid Wrapper with Solid Espresso Board Splits -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 md:py-16 space-y-16">
    
    <!-- 1. HERO SECTION -->
    <section class="border-2 border-[#3E2723] p-6 md:p-12 bg-[#09060B]/90 relative rounded-none overflow-hidden shadow-[0_0_30px_rgba(62,39,37,0.15)]">
      <!-- Accent Top Corner Label -->
      <div class="absolute top-0 right-0 bg-[#3E2723] text-purple-300 font-mono text-[10px] px-3 py-1 border-l border-b border-[#3E2723] uppercase select-none">
        [SYS.STATUS: OPERATIONAL]
      </div>

      <div class="max-w-4xl space-y-8">
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tighter uppercase text-[#FFFDD0] leading-none">
          Data, Decisions, and Systems <br class="hidden md:inline"/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-fuchsia-500 to-purple-400">That Actually Matter.</span>
        </h1>
        
        <p class="text-sm md:text-base leading-relaxed text-[#FFFDD0]/80 font-sans max-w-3xl">
          Data scientist and analytics engineer with 5+ years of experience across AdTech, consulting, automobile insurance claims, and applied machine learning—building models, pipelines, experiments, and analytical products that solve real business problems.
        </p>

        <!-- Focus Badges (hard-bordered boxes) -->
        <div class="flex flex-wrap gap-2 pt-2">
          {focusBadges.map((badge) => (
            <span class="border border-purple-800 bg-[#3E2723]/30 text-[#FFFDD0] font-mono text-xs uppercase px-3 py-1.5 rounded-none select-none hover:border-fuchsia-500 hover:bg-[#3E2723]/60 transition-colors">
              {badge}
            </span>
          ))}
        </div>

        <!-- Action CTAs -->
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 pt-6">
          <a href="#projects" class="bg-fuchsia-600 hover:bg-fuchsia-750 text-[#09060B] font-extrabold uppercase px-6 py-3.5 border border-fuchsia-500 text-center tracking-wider text-sm transition-all rounded-none">
            Explore Selected Work
          </a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="border border-[#3E2723] text-[#FFFDD0] hover:text-fuchsia-500 hover:bg-[#3E2723]/30 font-extrabold uppercase px-6 py-3.5 text-center tracking-wider text-sm transition-all rounded-none">
            Connect on LinkedIn
          </a>
        </div>
      </div>
    </section>

    <!-- 2. CORE SPECIALIZATIONS GRID -->
    <section id="specializations" class="space-y-4">
      <div class="flex items-center gap-4">
        <h2 class="text-xl md:text-2xl font-extrabold tracking-tight text-fuchsia-500 uppercase">// Core Specializations</h2>
        <div class="h-0.5 bg-[#3E2723]/50 flex-grow"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-4 border-2 border-[#3E2723] bg-[#09060B]/90 divide-y md:divide-y-0 md:divide-x divide-[#3E2723] rounded-none">
        {specializations.map((spec, idx) => (
          <div class="p-6 space-y-4 hover:bg-[#3E2723]/20 transition-colors duration-200">
            <div class="font-mono text-xs text-purple-400">[0{idx+1}]</div>
            <h3 class="text-lg font-extrabold text-[#FFFDD0] tracking-tight">{spec.title}</h3>
            <p class="text-xs md:text-sm leading-relaxed text-[#FFFDD0]/70 font-sans">{spec.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Split section grid: Interests on left, Current focus on right -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      
      <!-- 3. INTERESTS & PHILOSOPHY (7 cols) -->
      <section id="philosophy" class="lg:col-span-7 space-y-4">
        <div class="flex items-center gap-4">
          <h2 class="text-xl md:text-2xl font-extrabold tracking-tight text-fuchsia-500 uppercase">// What Drives Me</h2>
          <div class="h-0.5 bg-[#3E2723]/50 flex-grow"></div>
        </div>
        
        <div class="border-2 border-[#3E2723] bg-[#09060B]/90 p-6 rounded-none space-y-6">
          {philosophy.map((item) => (
            <div class="border-l-4 border-purple-800 pl-4 py-1 space-y-1">
              <h3 class="text-sm font-mono font-bold text-fuchsia-400 uppercase">{item.key}</h3>
              <p class="text-xs md:text-sm leading-relaxed text-[#FFFDD0]/85 font-sans">{item.val}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- 4. CURRENT BUILD MODE (5 cols) -->
      <section class="lg:col-span-5 space-y-4">
        <div class="flex items-center gap-4">
          <h2 class="text-xl md:text-2xl font-extrabold tracking-tight text-fuchsia-500 uppercase">// Current Focus</h2>
          <div class="h-0.5 bg-[#3E2723]/50 flex-grow"></div>
        </div>

        <div class="border-2 border-purple-800 bg-[#3E2723]/10 p-6 rounded-none relative overflow-hidden space-y-6 shadow-[inset_0_0_20px_rgba(217,70,239,0.03)]">
          <div class="absolute top-0 right-0 bg-[#3E2723] border-l border-b border-purple-800 text-fuchsia-400 font-mono text-[9px] font-bold px-2.5 py-1 uppercase tracking-wider">
            Active Learn
          </div>
          
          <p class="text-xs md:text-sm font-mono leading-relaxed text-[#FFFDD0]">
            "{currentFocus.copy}"
          </p>

          <ul class="space-y-3 font-sans text-xs md:text-sm text-[#FFFDD0]/85">
            {currentFocus.bullets.map((bullet) => (
              <li class="flex items-start gap-2.5">
                <span class="text-fuchsia-500 font-mono mt-1 font-bold">&gt;</span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    </div>

    <!-- 5. TECH STACK GRID -->
    <section class="space-y-4">
      <div class="flex items-center gap-4">
        <h2 class="text-xl md:text-2xl font-extrabold tracking-tight text-fuchsia-500 uppercase">// Tech Stack & Tooling</h2>
        <div class="h-0.5 bg-[#3E2723]/50 flex-grow"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-5 border-2 border-[#3E2723] bg-[#09060B]/90 divide-y md:divide-y-0 md:divide-x divide-[#3E2723] rounded-none">
        {techStack.map((stack) => (
          <div class="p-5 space-y-3">
            <h3 class="font-mono text-xs text-fuchsia-400 border-b border-[#3E2723] pb-2 uppercase tracking-wider">{stack.category}</h3>
            <ul class="space-y-1.5">
              {stack.items.map((item) => (
                <li class="font-mono text-xs md:text-sm text-[#FFFDD0]/90 flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 bg-[#3E2723] border border-purple-850 inline-block"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Split layout: Timeline (left/7cols) and Projects (right/5cols) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      
      <!-- 6. TRACK RECORD & EXPERIENCE (7 cols) -->
      <section id="experience" class="lg:col-span-7 space-y-4">
        <div class="flex items-center gap-4">
          <h2 class="text-xl md:text-2xl font-extrabold tracking-tight text-fuchsia-500 uppercase">// Track Record</h2>
          <div class="h-0.5 bg-[#3E2723]/50 flex-grow"></div>
        </div>

        <div class="border-2 border-[#3E2723] bg-[#09060B]/90 p-6 rounded-none space-y-8 relative">
          <!-- Central timeline vertical spine -->
          <div class="absolute left-6 top-8 bottom-8 w-0.5 bg-[#3E2723]/60 hidden sm:block"></div>
          
          {timeline.map((job) => (
            <div class="relative sm:pl-10 space-y-2">
              <!-- Timeline node dot -->
              <div class="absolute left-4 top-2 w-3.5 h-3.5 border-2 border-fuchsia-500 bg-[#09060B] rounded-none hidden sm:block"></div>
              
              <div class="flex flex-wrap items-center gap-2">
                <span class="font-mono text-xs px-2 py-0.5 bg-[#3E2723] border border-[#3E2723] text-fuchsia-300 rounded-none">
                  {job.time}
                </span>
                <h3 class="text-lg font-extrabold text-[#FFFDD0] tracking-tight">{job.company}</h3>
              </div>
              <p class="text-xs md:text-sm leading-relaxed text-[#FFFDD0]/75 font-sans">
                {job.description}
              </p>
            </div>
          ))}
        </div>
      </section>

      <!-- 7. SELECTED PROJECTS CARDS (5 cols) -->
      <section id="projects" class="lg:col-span-5 space-y-4">
        <div class="flex items-center gap-4">
          <h2 class="text-xl md:text-2xl font-extrabold tracking-tight text-fuchsia-500 uppercase">// Selected Projects</h2>
          <div class="h-0.5 bg-[#3E2723]/50 flex-grow"></div>
        </div>

        <div class="space-y-4">
          {projects.map((proj) => (
            <div class="border-2 border-[#3E2723] bg-[#09060B]/90 p-5 rounded-none space-y-3 hover:border-purple-800 transition-colors duration-200">
              <div class="flex items-start justify-between gap-4">
                <h3 class="text-md font-extrabold text-[#FFFDD0] tracking-tight uppercase leading-snug">
                  {proj.title}
                </h3>
                <span class="font-mono text-[9px] px-2 py-0.5 border border-purple-900/60 text-purple-300 whitespace-nowrap bg-purple-950/20 uppercase rounded-none">
                  {proj.tag}
                </span>
              </div>
              <p class="text-xs md:text-sm leading-relaxed text-[#FFFDD0]/70 font-sans">
                {proj.description}
              </p>
            </div>
          ))}
        </div>
      </section>
    </div>

  </div>
</Layout>
